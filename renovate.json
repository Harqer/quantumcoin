{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:base",
    ":preserveSemverRanges",
    ":dependencyDashboard",
    ":automergePatch",
    ":automergeMinor"
  ],
  "schedule": ["before 5am on monday"],
  "labels": ["dependencies", "renovate"],
  "commitMessageAction": "build(deps): update",
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    }
  ]
}
