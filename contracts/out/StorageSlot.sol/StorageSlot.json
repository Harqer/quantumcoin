":"t_struct$_BytesSlot_$9211_storage_ptr","typeString":"struct StorageSlot.BytesSlot"},"typeName":{"id":9305,"nodeType":"UserDefinedTypeName","pathNode":{"id":9304,"name":"BytesSlot","nameLocations":["4073:9:46"],"nodeType":"IdentifierPath","referencedDeclaration":9211,"src":"4073:9:46"},"referencedDeclaration":9211,"src":"4073:9:46","typeDescriptions":{"typeIdentifier":"t_struct$_BytesSlot_$9211_storage_ptr","typeString":"struct StorageSlot.BytesSlot"}},"visibility":"internal"}],"src":"4072:21:46"},"scope":9311,"stateMutability":"pure","virtual":false,"visibility":"internal"}],"abstract":false,"baseContracts":[],"canonicalName":"StorageSlot","contractDependencies":[],"contractKind":"library","documentation":{"id":9190,"nodeType":"StructuredDocumentation","src":"219:1187:46","text":" @dev Library for reading and writing primitive types to specific storage slots.\n Storage slots are often used to avoid storage conflict when dealing with upgradeable contracts.\n This library helps with reading and writing to such slots without the need for inline assembly.\n The functions in this library return Slot structs that contain a `value` member that can be used to read or write.\n Example usage to set ERC-1967 implementation slot:\n ```solidity\n contract ERC1967 {\n     // Define the slot. Alternatively, use the SlotDerivation library to derive the slot.\n     bytes32 internal constant _IMPLEMENTATION_SLOT = 0x360894a13ba1a3210667c828492db98dca3e2076cc3735a920a3ca505d382bbc;\n     function _getImplementation() internal view returns (address) {\n         return StorageSlot.getAddressSlot(_IMPLEMENTATION_SLOT).value;\n     }\n     function _setImplementation(address newImplementation) internal {\n         require(newImplementation.code.length > 0);\n         StorageSlot.getAddressSlot(_IMPLEMENTATION_SLOT).value = newImplementation;\n     }\n }\n ```\n TIP: Consider using this library along with {SlotDerivation}."},"fullyImplemented":true,"linearizedBaseContracts":[9311],"name":"StorageSlot","nameLocation":"1415:11:46","scope":9312,"usedErrors":[],"usedEvents":[]}],"license":"MIT"},"id":46}