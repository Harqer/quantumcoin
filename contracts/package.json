{
  "name": "qlink-contracts",
  "version": "1.0.0",
  "description": "Quantum-safe cross-chain bridge contracts based on QLink paper",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy:local": "hardhat run scripts/deploy.js --network localhost",
    "deploy:base": "hardhat run scripts/deploy.js --network base",
    "verify:base": "hardhat verify --network base",
    "postinstall": "npx -y patch-package"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^7.0.0",
    "@openzeppelin/contracts": "^5.0.0",
    "hardhat": "^3.9.0"
  },
  "dependencies": {
    "@openzeppelin/contracts-upgradeable": "^5.6.1",
    "@openzeppelin/hardhat-upgrades": "^1.28.0",
    "axios": "^1.18.1",
    "esbuild": "^0.28.1",
    "form-data": "^4.0.6",
    "protobufjs": "^8.6.5",
    "undici": "^8.5.0",
    "uuid": "^14.0.1"
  },
  "overrides": {
    "elliptic": "^6.6.1",
    "ws": "^8.20.1",
    "js-cookie": "^3.0.6"
  }
}
