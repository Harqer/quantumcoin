{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile",
    "dockerfilePath": "QubitCoin/quantum_backend/Dockerfile"
  },
  "deploy": {
    "startCommand": "python -m uvicorn quantum_backend.server:app --host 0.0.0.0 --port ${PORT:-8000} --workers ${SERVER_WORKERS:-4}",
    "restartPolicyType": "on_failure"
  }
}
