// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("PRIMARY_DB_CONNECTION_STRING")
}

model User {
  id                          String          @id @default(uuid())
  email                       String          @unique
  name                        String?
  firstName                   String?
  lastName                    String?
  dob                         String? // YYYY-MM-DD
  ssn                         String?
  ssnLast4                    String?
  addressStreet               String?
  addressCity                 String?
  addressState                String?
  addressZip                  String?
  stripeCustomerId            String? // Added for Stripe Customer flow
  stripeConnectAccountId      String? // Added for Stripe Connect payouts
  spendingPower               Float           @default(0) // Maximum limit or available funds for advances.
  subscriptionNextBillingDate DateTime? // Relevant for premium subscriptions.
  invitedUserReward           Float           @default(0) // Reward amount for successful referrals.
  totalToRepay                Float           @default(0) // The total outstanding balance the user owes.
  walletBalance               Float           @default(0) // Centralized wallet balance tracked across transactions.
  minDepositAmount            Float           @default(0) // Minimum limit for deposit thresholds.
  boosts                      Json? // Rewards or score multipliers that increase limits.
  last4_digits                String? // Last four digits of linked bank account.
  cleo_card                   Boolean         @default(false) // States whether the user has the Credit Builder Card.
  phoneNumber                 String?
  preferences                 Json?
  bankAccounts                BankAccount[]
  transactions                Transaction[]
  paymentMethods              PaymentMethod[]
  kycStatus                   String? // e.g., 'pending', 'verified', 'rejected'
  ewaDisclaimerAccepted       Boolean         @default(false)
  socureDeviceId              String? // For identity verification device tracking
  subscriptions               Subscription[]
  incomeSources               IncomeSource[]
  budgets                     Budget[]
  chatSessions                ChatSession[]
  cashAdvances                CashAdvance[]
  passkeys                    PasskeyCredential[]
  deviceSessions              DeviceSession[]
  auditLogs                   AuditLog[]
  insights                    Insight[]
  stakingPositions            StakingPosition[]
  createdAt                   DateTime        @default(now())
  updatedAt                   DateTime        @updatedAt
}

model BankAccount {
  id               String        @id @default(uuid())
  userId           String
  user             User          @relation(fields: [userId], references: [id])
  accessToken      String // Plaid access_token (Encrypted)
  iv               String? // AES-GCM Initialization Vector
  itemId           String // Plaid item_id
  stripeBankId     String? // The Stripe Bank Account Source ID
  currentBalance   Float? // Cached balance from Plaid
  availableBalance Float? // Cached available balance
  transactions     Transaction[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([itemId])
}

model Transaction {
  id                    String       @id @default(uuid())
  userId                String
  user                  User         @relation(fields: [userId], references: [id])
  bankAccountId         String?
  bankAccount           BankAccount? @relation(fields: [bankAccountId], references: [id])
  categoryId            String?
  category              Category?    @relation(fields: [categoryId], references: [id])
  stripePaymentIntentId String?      @unique // Used to deduplicate Stripe webhooks
  type                  String       @default("debit") // 'credit', 'debit', 'salary_advance', 'auto_save', 'repayment'
  direction             String?      // 'in' or 'out'
  amount                Float
  selectedAmount        Float? // The amount chosen for a transaction or withdrawal.
  currency              String       @default("usd")
  status                String       @default("completed") // 'pending', 'completed', 'failed'
  logoUrl               String?
  lastFormatted         String? // Formatted string representation of the last transaction or balance.
  merchantName          String? // The name of the merchant/connected institution.
  description           String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([userId])
  @@index([bankAccountId])
}

model PaymentMethod {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  customerId String // Stripe customer_id
  type       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Subscription {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  tier        String // e.g., 'plus', 'builder'
  status      String // e.g., 'active', 'canceled'
  stripeSubId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model IncomeSource {
  id           String        @id @default(uuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id])
  employerName String
  frequency    String // e.g., 'biweekly', 'monthly'
  amount       Float
  pinwheelId   String? // Reference to Pinwheel connection
  cashAdvances CashAdvance[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

enum BillingCycle {
  WEEKLY
  BIWEEKLY
  MONTHLY
  YEARLY
}

model Budget {
  id            String        @id @default(uuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  limit         Float
  money         Float         @default(0) // Internal representation of localized currency.
  billingCycle  BillingCycle? // Frequency of the budget.
  serviceFeeCap Float? // The maximum fee applied for services or overdrafts.
  categories    Category[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([userId])
}

model Category {
  id           String        @id @default(uuid())
  budgetId     String
  budget       Budget        @relation(fields: [budgetId], references: [id])
  name         String
  limit        Float
  spent        Float         @default(0)
  icon         String?
  color        String?
  transactions Transaction[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([budgetId])
}

model ChatSession {
  id               String        @id @default(uuid())
  userId           String
  user             User          @relation(fields: [userId], references: [id])
  subscriptionName String? // Detects the user's tier to dictate chatbot tone or feature access.
  bankName         String? // Contextualizes the chat based on user's linked institutions.
  mode             String? // 'roast' or 'hype'
  messages         ChatMessage[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model ChatMessage {
  id            String      @id @default(uuid())
  chatSessionId String
  session       ChatSession @relation(fields: [chatSessionId], references: [id])
  role          String // 'user' or 'ai'
  content       String      @db.Text
  metadata      Json?
  createdAt     DateTime    @default(now())

  @@index([chatSessionId])
}

model CashAdvance {
  id                String        @id @default(uuid())
  userId            String
  user              User          @relation(fields: [userId], references: [id])
  incomeSourceId    String?
  incomeSource      IncomeSource? @relation(fields: [incomeSourceId], references: [id])
  amount            Float
  totalToRepay      Float         @default(0) // Current owed amount.
  spendingPower     Float         @default(0) // Limit approved by the underwriting engine.
  totalBoostsAmount Float         @default(0) // Applied boosts increasing the advance limit.
  serviceFeeCap     Float? // Express fee limits applied to the advance.
  status            String // 'pending', 'approved', 'funded', 'repaid'
  repaymentDate     DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

model PasskeyCredential {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  credentialId   String   @unique
  publicKey      Bytes
  signCount      Int      @default(0)
  transports     String?  // JSON array of transports
  deviceName     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model DeviceSession {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  socureDeviceId   String
  ipAddress        String?
  userAgent        String?
  appCheckToken    String?
  integrityVerdict String?
  seonFingerprint  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model AuditLog {
  id              String   @id @default(uuid())
  userId          String?
  user            User?    @relation(fields: [userId], references: [id])
  requestId       String
  action          String
  providerOutcome String?
  metadata        Json?
  timestamp       DateTime @default(now())
}

model Insight {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  type        String   // e.g., 'SPENDING_ALERT', 'SUBSCRIPTION_FEE'
  title       String
  description String?
  amount      Float?
  actionUrl   String?
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model StakingPosition {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  poolId        String
  amountStaked  String
  earnedRewards String   @default("0")
  stakedAt      DateTime @default(now())
  unlocksAt     DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
}

model TradeOrder {
  id                 String   @id @default(uuid())
  clientOrderId      String   @unique
  productId          String
  side               String
  type               String
  status             String
  baseSize           String?
  quoteSize          String?
  limitPrice         String?
  filledSize         String   @default("0")
  averageFilledPrice String   @default("0")
  commission         String   @default("0")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model PaymentSession {
  id        String   @id @default(uuid())
  chargeId  String   @unique
  productId String?
  amount    String
  currency  String
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TelemetryLog {
  id         String   @id @default(uuid())
  commandId  String   @unique
  agentId    String
  action     String
  parameters Json?
  status     String   @default("pending")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
